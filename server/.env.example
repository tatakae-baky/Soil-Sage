# MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/soil-sage

# Server port
PORT=5000

# JWT signing secret (use a long random string in production)
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32

# Optional: comma-separated origins for CORS (defaults to localhost Vite ports)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: seed first admin (npm run seed:admin)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=your-secure-password
# ADMIN_NAME=Admin
